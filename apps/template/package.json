{
	"type": "module",
	"sideEffects": false,
	"name": "@ai-toolkit/template",

	"imports": {
		"#lib/*": "./src/lib/*",
		"#rpcs/*": "./src/rpcs/*",
		"#routes/*": "./src/routes/*"
	},

	"scripts": {
		"dev:client": "vite dev --port 5173",
		"dev:server": "bun --watch ./src/main.server.tsx",

		"build:client": "vite build",
		"build:server": "bun build ./src/main.server.tsx --compile --outfile ./dist/backend",

		"fix": "biome check --write --unsafe && effect-language-service quickfixes --project ./tsconfig.json",
		"check": "tsgo --noEmit && biome check && effect-language-service diagnostics --project ./tsconfig.json"
	},

	"dependencies": {
		"react": "^19",
		"react-dom": "^19",
		"@tanstack/react-router": "latest",
		"@tanstack/router-plugin": "latest",
		"ai": "latest",
		"exa-js": "latest",

		"@ai-toolkit/ai": "workspace:*",
		"@ai-toolkit/oauth": "workspace:*",
		"@ai-toolkit/components": "workspace:*",
		"@ai-toolkit/opentelemetry": "workspace:*"
	},

	"devDependencies": {
		"vite": "^8.0.0-beta",
		"vite-bundle-analyzer": "latest",
		"@vitejs/plugin-react": "latest",
		"babel-plugin-react-compiler": "latest",

		"tailwindcss": "latest",
		"@tailwindcss/vite": "latest"
	}
}
