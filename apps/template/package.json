{
	"type": "module",
	"name": "@ai-toolkit/template",

	"imports": {
		"#lib/*": "./src/lib/*",
		"#convex/*": "./convex/_generated/*"
	},

	"scripts": {
		"dev:vite": "vite dev --port 5173",
		"dev:convex": "convex dev",
		"build": "vite build --emptyOutDir",

		"fix": "biome check --write --unsafe && effect-language-service quickfixes --project ./tsconfig.json",
		"check": "tsgo --noEmit && biome check && effect-language-service diagnostics --project ./tsconfig.json"
	},

	"dependencies": {
		"react": "^19",
		"react-dom": "^19",
		"@tanstack/react-start": "latest",
		"@tanstack/react-query": "latest",
		"@tanstack/react-router": "latest",
		"@tanstack/react-router-with-query": "latest",

		"convex": "latest",
		"@convex-dev/react-query": "latest",

		"@ai-toolkit/ai": "workspace:*",
		"@ai-toolkit/components": "workspace:*",
		"@ai-toolkit/opentelemetry": "workspace:*"
	},

	"devDependencies": {
		"nitro": "latest",
		"vite": "npm:rolldown-vite@latest",
		"@vitejs/plugin-react": "latest",
		"babel-plugin-react-compiler": "latest",

		"tailwindcss": "latest",
		"@tailwindcss/vite": "latest"
	}
}
