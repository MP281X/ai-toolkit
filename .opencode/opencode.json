{
  "$schema": "https://opencode.ai/config.json",

  "tools": { "question": true, "codesearch": false },

  "mcp": {
    "btca": {
			"type": "local",
      "timeout": 600000,
			"command": ["bunx", "btca", "mcp"]
		}
  },

  "permission": {
    "bash": {
      "*": "allow",
      "npm *": "deny",
      "pnpm *": "deny",
      "gh *": "ask",
      "git *": "ask",
      "git *log*": "allow",
      "git *diff*": "allow",
      "git *show*": "allow",
      "git *status*": "allow",
      "git *rev-parse*": "allow"
    }
  }
}
