{
  "$schema": "https://opencode.ai/config.json",

  "mcp": {
    "grep_app": {
      "type": "remote",
      "url": "https://mcp.grep.app"
    }
  },

  "permission": {
    "bash": {
      "*": "allow",
      "npm *": "deny",
      "pnpm *": "deny",
      "gh *": "ask",
      "git *": "ask",
      "git *log*": "allow",
      "git *diff*": "allow",
      "git *show*": "allow",
      "git *status*": "allow",
      "git *rev-parse*": "allow"
    }
  }
}
