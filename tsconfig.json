{
	"compilerOptions": {
		// effect-ts lsp
		"plugins": [{ "name": "@effect/language-service" }],

		// type checking
		"strict": true,
		"noErrorTruncation": true,
		"noImplicitReturns": true,
		"noImplicitOverride": true,
		"allowUnusedLabels": false,
		"noUncheckedIndexedAccess": true,
		"noFallthroughCasesInSwitch": true,
		"exactOptionalPropertyTypes": false,
		"noPropertyAccessFromIndexSignature": true,

		// ts version and module resolution (use the lasted ts/js features and types)
		"lib": ["ESNext", "dom", "dom.iterable"],
		"jsx": "react-jsx",
		"target": "ESNext",
		"module": "ESNext",
		"moduleDetection": "force",
		"moduleResolution": "bundler",

		// imports / type checking and parsing / ...
		"allowJs": true,
		"checkJs": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"isolatedModules": true,
		"resolveJsonModule": true,
		"verbatimModuleSyntax": true,
		"useDefineForClassFields": true,
		"allowImportingTsExtensions": true,
		"noUncheckedSideEffectImports": true,
		"allowSyntheticDefaultImports": true,

		// build config
		"noEmit": true,
		"sourceMap": true,
		"incremental": true,
		"tsBuildInfoFile": ".tsbuildinfo"
	},

	"exclude": ["${configDir}/**/node_modules", "${configDir}/**/dist", "${configDir}/**/.output"],
	"include": ["${configDir}/src/**/*", "${configDir}/*.config.*"]
}
