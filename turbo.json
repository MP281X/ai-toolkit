{
	"ui": "tui",
	"$schema": "https://turbo.build/schema.json",

	"globalEnv": ["NODE_*"],
	"globalDependencies": ["bun.lock", "biome.json", "tsconfig.json"],

	"tasks": {
		"dev:client": { "cache": false, "persistent": true },
		"dev:server": { "cache": false, "persistent": true },

		"build": { "dependsOn": ["^check", "^build"], "outputs": ["dist/**", ".output/**"] },

		"fix": { "cache": false },
		"check": { "cache": false }
	}
}
