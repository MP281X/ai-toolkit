{
	"ui": "tui",
	"$schema": "https://turbo.build/schema.json",

	"globalEnv": ["NODE_*", "VITE_*"],
	"globalDependencies": ["bun.lock", "biome.json", "tsconfig.json"],

	"tasks": {
		"dev": { "cache": false, "persistent": true },
		"build": { "dependsOn": ["^check"], "outputs": [".output/**"] },
		"preview": { "dependsOn": ["build"], "cache": false, "persistent": true },

		"fix": {},
		"check": {}
	}
}
