{
	"$schema": "node_modules/@biomejs/biome/configuration_schema.json",

	"linter": {
		"domains": { "react": "recommended" },
		"rules": {
			"complexity": {
				"useLiteralKeys": "off",
				"useArrowFunction": "warn",
				"noUselessStringConcat": "warn",
				"useSimplifiedLogicExpression": "warn"
			},
			"suspicious": {
				"noConsole": "error",
				"noExplicitAny": "off",
				"noConfusingVoidType": "off",
				"noAssignInExpressions": "off",
				"noShadowRestrictedNames": "off"
			},
			"style": {
				"useNumberNamespace": "warn",
				"useAsConstAssertion": "warn",
				"useEnumInitializers": "warn",
				"useDefaultParameterLast": "warn",
				"noUnusedTemplateLiteral": "warn",
				"useConsistentArrayType": { "level": "error", "options": { "syntax": "shorthand" } },
				"noRestrictedGlobals": {
					"level": "error",
					"options": {
						"deniedGlobals": {
							"global": "use globalThis",
							"location": "Use Tanstack router",
							"Array": "Import Array from 'effect' instead",
							"Number": "Import Number from 'effect' instead",
							"String": "Import String from 'effect' instead",
							"Object": "Import Record from 'effect' instead"
						}
					}
				}
			},
			"correctness": {
				"useYield": "off",
				"noChildrenProp": "off",
				"noUnusedImports": "off",
				"noUnusedVariables": "off",
				"useImportExtensions": "error",
				"noUndeclaredDependencies": "off",
				"noUnusedFunctionParameters": "off"
			},
			"nursery": {
				"noFloatingPromises": "warn",
				"useSortedClasses": { "level": "error", "fix": "safe" }
			}
		}
	},

	"formatter": { "lineWidth": 120, "formatWithErrors": true },
	"assist": {
		"actions": {
			"source": {
				"organizeImports": {
					"level": "on",
					"options": {
						"groups": [
							["side-effect", "side-effect-style"],
							":BLANK_LINE:",
							[":NODE:"],
							":BLANK_LINE:",
							["@effect/**"],
							["effect"],
							":BLANK_LINE:",
							[":PACKAGE:"],
							":BLANK_LINE:",
							["@ai-toolkit/**"],
							":BLANK_LINE:",
							["@/", "#", "~"],
							":BLANK_LINE:",
							["../"],
							["./"]
						]
					}
				}
			}
		}
	},

	"html": { "formatter": { "indentScriptAndStyle": true } },
	"css": {
		"formatter": { "enabled": true },
		"parser": { "cssModules": true, "tailwindDirectives": true }
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single",
			"semicolons": "asNeeded",
			"trailingCommas": "none",
			"arrowParentheses": "asNeeded",
			"bracketSpacing": false
		}
	},

	"vcs": { "enabled": true, "clientKind": "git", "useIgnoreFile": true },
	"files": {
		"includes": ["**/*.ts", "**/*.tsx", "**/*.css", "**/*.html", "**/*.json", "**/*.jsonc", "!**/*.gen.ts"]
	},

	"overrides": [
		{
			"includes": ["**/package.json"],
			"json": { "formatter": { "expand": "auto" } }
		},
		{
			"includes": ["**/components/ui/*.tsx"],
			"linter": {
				"rules": {
					"style": {
						"noRestrictedGlobals": "off"
					},
					"suspicious": {
						"noDoubleEquals": "off",
						"noArrayIndexKey": "off"
					},
					"security": {
						"noDangerouslySetInnerHtml": "off"
					},
					"a11y": {
						"useValidAriaRole": "off",
						"useSemanticElements": "off",
						"useKeyWithClickEvents": "off",
						"noLabelWithoutControl": "off"
					}
				}
			}
		}
	]
}
