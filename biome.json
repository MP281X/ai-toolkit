{
	"$schema": "node_modules/@biomejs/biome/configuration_schema.json",

	"linter": {
		"domains": { "react": "recommended" },
		"rules": {
			"complexity": {
				"useLiteralKeys": "off",
				"useArrowFunction": "off",
				"noUselessStringConcat": "warn",
				"useSimplifiedLogicExpression": "warn"
			},
			"suspicious": {
				"noConsole": "error",
				"noExplicitAny": "error",
				"noConfusingVoidType": "off",
				"noAssignInExpressions": "off",
				"noShadowRestrictedNames": "off",
				"useIterableCallbackReturn": "off"
			},
			"style": {
				"noUselessElse": "error",
				"noNestedTernary": "error",
				"noInferrableTypes": "error",
				"useNumberNamespace": "warn",
				"noNonNullAssertion": "error",
				"useCollapsedElseIf": "error",
				"useAsConstAssertion": "warn",
				"useEnumInitializers": "warn",
				"noParameterProperties": "error",
				"useDefaultParameterLast": "warn",
				"noUnusedTemplateLiteral": "warn",
				"useConsistentTypeDefinitions": { "level": "error", "options": { "style": "type" } },
				"useConsistentArrayType": { "level": "error", "options": { "syntax": "shorthand" } },
				"noRestrictedImports": {
					"level": "error",
					"options": {
						"paths": {
							"react": {
								"importNames": ["useCallback", "useEffect", "useMemo"],
								"message": "Do not use useCallback/useEffect/useMemo; prefer alternative patterns."
							}
						}
					}
				},
				"noRestrictedGlobals": {
					"level": "error",
					"options": {
						"deniedGlobals": {
							"global": "use globalThis",
							"location": "Use Tanstack router",
							"Array": "Import Array from 'effect' instead",
							"Number": "Import Number from 'effect' instead",
							"String": "Import String from 'effect' instead",
							"Object": "Import Record from 'effect' instead"
						}
					}
				}
			},
			"correctness": {
				"useYield": "off",
				"noChildrenProp": "off",
				"noUnusedImports": "off",
				"noUnusedVariables": "off",
				"useHookAtTopLevel": "error",
				"useImportExtensions": "error",
				"noUndeclaredDependencies": "off",
				"noUnusedFunctionParameters": "off"
			},
			"nursery": {
				"noFloatingPromises": "warn",
				"useSortedClasses": { "level": "error", "fix": "safe" }
			}
		}
	},

	"formatter": { "lineWidth": 120, "formatWithErrors": true },
	"assist": {
		"actions": {
			"source": {
				"organizeImports": {
					"level": "on",
					"options": {
						"groups": [
							["side-effect", "side-effect-style"],
							":BLANK_LINE:",
							[":NODE:"],
							":BLANK_LINE:",
							["@effect/**"],
							["effect"],
							":BLANK_LINE:",
							[":PACKAGE:"],
							":BLANK_LINE:",
							["@ai-toolkit/**"],
							":BLANK_LINE:",
							["@/", "#", "~"],
							":BLANK_LINE:",
							["../"],
							["./"]
						]
					}
				}
			}
		}
	},

	"html": { "formatter": { "indentScriptAndStyle": true } },
	"css": {
		"formatter": { "enabled": true },
		"parser": { "cssModules": true, "tailwindDirectives": true }
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single",
			"semicolons": "asNeeded",
			"trailingCommas": "none",
			"arrowParentheses": "asNeeded",
			"bracketSpacing": false
		}
	},

	"vcs": { "enabled": true, "clientKind": "git", "useIgnoreFile": true },
	"files": {
		"includes": [
			"**/*.ts",
			"**/*.tsx",
			"**/*.css",
			"**/*.html",
			"**/*.json",
			"**/*.jsonc",
			"!**/*.gen.ts",
			"!**/routeTree.gen.ts"
		]
	},

	"overrides": [
		{
			"includes": ["**/package.json"],
			"json": { "formatter": { "expand": "auto" } }
		},
		{
			"includes": ["**/components/ui/*.tsx"],
			"linter": {
				"rules": {
					"style": {
						"noNonNullAssertion": "off",
						"noRestrictedImports": "off",
						"noRestrictedGlobals": "off",
						"useConsistentTypeDefinitions": "off"
					},
					"suspicious": {
						"noExplicitAny": "off",
						"noDoubleEquals": "off",
						"noArrayIndexKey": "off"
					},
					"security": {
						"noDangerouslySetInnerHtml": "off"
					},
					"a11y": {
						"useValidAriaRole": "off",
						"useSemanticElements": "off",
						"noLabelWithoutControl": "off",
						"useKeyWithClickEvents": "off"
					},
					"correctness": {
						"noUnusedImports": "off",
						"noUnusedVariables": "off",
						"noUnusedFunctionParameters": "off"
					}
				}
			}
		}
	]
}
