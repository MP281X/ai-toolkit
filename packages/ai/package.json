{
	"type": "module",
	"sideEffects": false,
	"name": "@ai-toolkit/ai",

	"exports": {
		"./schema": "./src/schema.ts",
		"./catalog": "./src/catalog.ts",
		"./service": "./src/service.ts",
		"./agents/ai-sdk": "./src/agents/ai-sdk.ts",
		"./agents/copilot-sdk": "./src/agents/copilot-sdk.ts"
