		"@ai-sdk/xai": "latest",
		"@ai-sdk/openai": "latest",
		"@ai-sdk/google": "latest",
		"@ai-sdk/anthropic": "latest",
		"@ai-sdk/openai-compatible": "latest",
		"@openrouter/ai-sdk-provider": "latest"
	}
