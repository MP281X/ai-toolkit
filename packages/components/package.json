{
	"type": "module",
	"sideEffects": false,
	"name": "@ai-toolkit/components",

	"imports": {
		"#lib/*": "./src/lib/*",
		"#hooks/*": "./src/hooks/*",
		"#components/*": "./src/components/*"
	},

	"exports": {
		"./*": "./src/components/*.tsx",
		"./utils": "./src/lib/utils.ts",
		"./theme.css": "./src/theme.css"
	},

	"scripts": {
		"fix": "biome check --write --unsafe",
		"check": "tsgo --noEmit && biome check"
	},

	"dependencies": {
		"cmdk": "latest",
		"@base-ui/react": "^1",
		"react-resizable-panels": "latest",

		"lucide-react": "latest",
		"@icons-pack/react-simple-icons": "latest",

		"lexical": "latest",
		"@lexical/react": "latest",
		"@lexical/utils": "latest",

		"shiki": "latest",
		"marked": "latest",
		"@ai-toolkit/ai": "workspace:*",

		"clsx": "latest",
		"tailwind-merge": "latest",
		"tw-animate-css": "latest",
		"class-variance-authority": "latest",
		"@fontsource-variable/jetbrains-mono": "latest"
	},
	"peerDependencies": {
		"react": "^19",
		"react-dom": "^19",

		"shadcn": "latest",
		"tailwindcss": "^4"
	}
}
