{
	"type": "module",
	"name": "@ai-toolkit",
	"sideEffects": false,
	"packageManager": "bun@1.3.8",
	"workspaces": ["apps/*", "packages/*"],

	"scripts": {
		"dev": "turbo run dev:client dev:server",

		"build": "NODE_ENV=production turbo run build:client build:server",

		"shadcn": "cd packages/components && bunx shadcn@latest",

		"fix": "turbo run fix",
		"check": "turbo run check"
	},

	"dependencies": {
		"effect": "latest",
		"@effect/platform": "latest",
		"@effect/platform-bun": "latest",
		"@effect-atom/atom-react": "latest"
	},

	"devDependencies": {
		"turbo": "2.8.3",
		"@biomejs/biome": "latest",

		"typescript": "latest",
		"@effect/language-service": "latest",
		"@typescript/native-preview": "latest",

		"@types/bun": "latest",
		"@types/react": "^19",
		"@types/react-dom": "^19"
	}
}
