{
	"type": "module",
	"name": "@ai-toolkit",
	"packageManager": "bun@1.3.6",
	"workspaces": ["apps/*", "packages/*"],

	"trustedDependencies": ["@rocicorp/zero-sqlite3"],

	"scripts": {
		"dev": "turbo run dev:vite dev:zero",
		"build": "NODE_ENV=production turbo run build",

		"db:up": "docker run -d --name zero-postgres -e POSTGRES_PASSWORD='password' -e POSTGRES_INITDB_ARGS='-c wal_level=logical' -p 5432:5432 postgres:16-alpine",
		"db:down": "docker stop zero-postgres && docker rm zero-postgres",

		"shadcn": "cd packages/components && bunx shadcn@latest",

		"fix": "turbo run fix",
		"check": "turbo run check"
	},

	"dependencies": {
		"effect": "latest",
		"@effect/platform": "latest",
		"@effect-atom/atom-react": "latest"
	},

	"devDependencies": {
		"turbo": "latest",
		"@biomejs/biome": "latest",

		"typescript": "latest",
		"@effect/language-service": "latest",
		"@typescript/native-preview": "latest",

		"@types/bun": "latest",
		"@types/react": "^19",
		"@types/react-dom": "^19"
	}
}
