		"@effect/platform-bun": "^4.0.0-beta"
	},

	"devDependencies": {
		"turbo": "latest",
		"@biomejs/biome": "latest",

		"typescript": "latest",
		"@typescript/native-preview": "latest",

		"@types/bun": "latest",
		"@types/react": "^19",
		"@types/react-dom": "^19"
	}
}
