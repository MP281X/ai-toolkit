{
	"type": "module",
	"name": "@ai-toolkit",
	"sideEffects": false,
	"packageManager": "bun@1.3.8",
	"workspaces": ["apps/*", "packages/*", ".opencode"],

	"scripts": {
		"dev": "turbo run dev",
		"build": "NODE_ENV=production turbo run build",
		"preview": "NODE_ENV=production turbo run preview",

		"shadcn": "cd packages/components && bunx shadcn@latest",

